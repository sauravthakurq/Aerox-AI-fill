{
  "manifest_version": 3,
  "name": "Aerox AI Fill",
  "version": "1.0.0",
  "description": "Extract text from PDFs or pasted text and auto-fill the current page's form using AI.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Aerox AI Fill",
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
